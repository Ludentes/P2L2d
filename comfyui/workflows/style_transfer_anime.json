{
  "1": {
    "class_type": "UNETLoader",
    "inputs": {"unet_name": "__MODEL__", "weight_dtype": "default"},
    "_meta": {"title": "Load FLUX Model"}
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5/t5xxl_fp8_e4m3fn.safetensors",
      "type": "flux"
    },
    "_meta": {"title": "Load CLIP-L + T5-XXL"}
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "FLUX1/ae.safetensors"},
    "_meta": {"title": "Load FLUX VAE"}
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {"image": "__IMAGE__", "upload": "image"},
    "_meta": {"title": "Load Portrait"}
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "anime style illustration, flat cell shading, clean crisp lines, vibrant colors",
      "clip": ["2", 0]
    },
    "_meta": {"title": "Positive Prompt"}
  },
  "6": {
    "class_type": "FluxGuidance",
    "inputs": {"conditioning": ["5", 0], "guidance": 3.5},
    "_meta": {"title": "FLUX Guidance"}
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["2", 0]},
    "_meta": {"title": "Negative (empty)"}
  },
  "8": {
    "class_type": "VAEEncode",
    "inputs": {"pixels": ["4", 0], "vae": ["3", 0]},
    "_meta": {"title": "Encode Image"}
  },
  "9": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["8", 0],
      "seed": 42,
      "steps": 20,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": "__STRENGTH__"
    },
    "_meta": {"title": "Sample"}
  },
  "10": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["9", 0], "vae": ["3", 0]},
    "_meta": {"title": "Decode"}
  },
  "11": {
    "class_type": "SaveImage",
    "inputs": {"images": ["10", 0], "filename_prefix": "p2l_style"},
    "_meta": {"title": "Save"}
  }
}
