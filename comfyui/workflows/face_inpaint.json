{
  "1": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "fluxFillFP8_v10.safetensors",
      "weight_dtype": "default"
    },
    "_meta": {"title": "Load FLUX Fill Model"}
  },
  "2": {
    "class_type": "DualCLIPLoader",
    "inputs": {
      "clip_name1": "clip_l.safetensors",
      "clip_name2": "t5/t5xxl_fp8_e4m3fn.safetensors",
      "type": "flux"
    },
    "_meta": {"title": "Load CLIP-L + T5-XXL"}
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {"vae_name": "FLUX1/ae.safetensors"},
    "_meta": {"title": "Load FLUX VAE"}
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": {"image": "__IMAGE__", "upload": "image"},
    "_meta": {"title": "Load Face Crop"}
  },
  "5": {
    "class_type": "LoadImage",
    "inputs": {"image": "__MASK__", "upload": "image"},
    "_meta": {"title": "Load Mask"}
  },
  "6": {
    "class_type": "ImageToMask",
    "inputs": {"image": ["5", 0], "channel": "red"},
    "_meta": {"title": "Convert to Mask"}
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "__PROMPT__", "clip": ["2", 0]},
    "_meta": {"title": "Positive Prompt"}
  },
  "8": {
    "class_type": "FluxGuidance",
    "inputs": {"conditioning": ["7", 0], "guidance": 30.0},
    "_meta": {"title": "FLUX Guidance"}
  },
  "9": {
    "class_type": "CLIPTextEncode",
    "inputs": {"text": "", "clip": ["2", 0]},
    "_meta": {"title": "Negative (empty)"}
  },
  "10": {
    "class_type": "InpaintModelConditioning",
    "inputs": {
      "positive": ["8", 0],
      "negative": ["9", 0],
      "vae": ["3", 0],
      "pixels": ["4", 0],
      "mask": ["6", 0],
      "noise_mask": true
    },
    "_meta": {"title": "Inpaint Conditioning"}
  },
  "11": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["1", 0],
      "positive": ["10", 0],
      "negative": ["10", 1],
      "latent_image": ["10", 2],
      "seed": 42,
      "steps": 20,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0
    },
    "_meta": {"title": "Sample"}
  },
  "12": {
    "class_type": "VAEDecode",
    "inputs": {"samples": ["11", 0], "vae": ["3", 0]},
    "_meta": {"title": "Decode"}
  },
  "13": {
    "class_type": "SaveImage",
    "inputs": {"images": ["12", 0], "filename_prefix": "p2l_inpaint"},
    "_meta": {"title": "Save"}
  }
}
